  <blockTypes typeName="JoinText" label="Join text" colour="230" categoryName="Expressions" superTypeName="TextExpression" connectionType="OUTPUT_TYPED" outputType="TextExpression" tooltip="Concatenate two text expressions." codeTemplate="String({{value:left}}) + String({{value:right}})">
