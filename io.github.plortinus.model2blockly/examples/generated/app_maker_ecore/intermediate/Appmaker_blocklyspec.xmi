  <blockTypes typeName="SubmitForm" label="Submit form" colour="30" categoryName="Actions" superTypeName="Action" connectionType="TYPED" connectionTypeName="Action" tooltip="Submit form data to a data source and optionally navigate." codeTemplate="submitForm(&quot;{{endpoint}}&quot;, &quot;{{successTarget}}&quot;);">
    <orderedInputNames>endpoint</orderedInputNames>
    <orderedInputNames>successTarget</orderedInputNames>
    <referenceFields name="endpoint" targetTypeName="DataSource" required="true" lowerBound="1" uiWidget="reference-select" uiLabel="Endpoint" uiGroup="Action" uiOrder="1" referenceLabelField="name"/>
    <referenceFields name="successTarget" targetTypeName="Page" uiWidget="reference-select" uiLabel="Success page" uiGroup="Action" uiOrder="2" referenceLabelField="title"/>
  </blockTypes>
  <blockTypes typeName="SetInputValue" label="Set input value" colour="30" categoryName="Actions" superTypeName="Action" connectionType="TYPED" connectionTypeName="Action" tooltip="Set a text input value from an expression." codeTemplate="setInputValue(&quot;{{input}}&quot;, {{value:newValue}});">
    <orderedInputNames>input</orderedInputNames>
    <orderedInputNames>newValue</orderedInputNames>
    <referenceFields name="input" targetTypeName="TextInput" required="true" lowerBound="1" uiWidget="reference-select" uiLabel="Input" uiGroup="Action" uiOrder="1" referenceLabelField="name"/>
    <valueInputs name="newValue" checkType="TextExpression" shadowBlockType="TextLiteral" uiLabel="Value" uiGroup="Action" uiOrder="2"/>
