  <blockTypes typeName="OpenUrl" label="Open URL" colour="30" categoryName="Actions" superTypeName="Action" connectionType="TYPED" connectionTypeName="Action" tooltip="Open an external URL." codeTemplate="openUrl({{value:url}});">
