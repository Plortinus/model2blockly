  <blockTypes typeName="TextExpression" label="Text expression" colour="230" categoryName="Expressions" abstract="true" connectionType="OUTPUT" outputType="TextExpression" tooltip="Abstract text expression."/>
  <blockTypes typeName="TextLiteral" label="Text" colour="230" categoryName="Expressions" superTypeName="TextExpression" connectionType="OUTPUT_TYPED" outputType="TextExpression" inputsInline="true" tooltip="Literal text value." codeTemplate="&quot;{{content}}&quot;">
