<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="https://plortinus.github.io/model2blockly/ns/blockly-editor-spec" domainName="AppMaker" nsURI="http://www.example.org/appmaker" nsPrefix="appmaker" codeLanguage="javascript" codeFileExtension="js" runtimeKind="appMaker">
  <categories name="Pages" label="Pages" colour="260"/>
  <categories name="Components" label="Components" colour="160"/>
  <categories name="Layout" label="Layout" colour="120"/>
  <categories name="Actions" label="Actions" colour="30"/>
  <categories name="Data" label="Data" colour="210"/>
  <categories name="Expressions" label="Expressions" colour="230"/>
  <blockTypes typeName="DataSource" label="Data source" colour="210" categoryName="Data" connectionType="TYPED" connectionTypeName="DataSource" inputsInline="true" helpUrl="https://developers.google.com/blockly" codeTemplate="dataSource(&quot;{{name}}&quot;, {&#xA;url: &quot;{{url}}&quot;,&#xA;method: &quot;{{method}}&quot;,&#xA;cacheEnabled: &quot;{{cacheEnabled}}&quot; === &quot;TRUE&quot;&#xA;});" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>url</orderedInputNames>
    <orderedInputNames>method</orderedInputNames>
    <orderedInputNames>cacheEnabled</orderedInputNames>
    <orderedInputNames>retryCount</orderedInputNames>
    <orderedInputNames>headers</orderedInputNames>
    <fields name="name" defaultValue="tasks" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Data" uiOrder="1" uiVariant="default"/>
    <fields name="url" defaultValue="https://example.com/api/tasks" required="true" lowerBound="1" uiWidget="text" uiLabel="URL" uiGroup="Data" uiOrder="2" uiVariant="default"/>
    <fields name="method" fieldType="DROPDOWN" defaultValue="get" uiWidget="select" uiLabel="Method" uiGroup="Data" uiOrder="3" uiVariant="default">
      <options value="get" label="GET"/>
      <options value="post" label="POST"/>
      <options value="put" label="PUT"/>
      <options value="delete" label="DELETE"/>
    </fields>
    <fields name="cacheEnabled" fieldType="BOOLEAN" defaultValue="true" uiWidget="checkbox" uiLabel="Cache" uiGroup="Data" uiOrder="4" uiVariant="default"/>
    <fields name="retryCount" fieldType="INTEGER" defaultValue="3" min="0" max="10" uiWidget="number" uiLabel="Retries" uiGroup="Data" uiOrder="5" uiVariant="default"/>
    <fields name="headers" defaultValue="Authorization&#xA;X-Trace-Id" upperBound="10" unique="false" ordered="false" uiWidget="textarea" uiLabel="Headers" uiGroup="Data" uiOrder="6" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="App" label="App" colour="260" categoryName="Pages" connectionType="NONE" inputsInline="true" tooltip="Root low-code app model." codeTemplate="app(&quot;{{name}}&quot;, {&#xA;theme: &quot;{{theme}}&quot;,&#xA;dataSources: [&#xA;{{statements:dataSources}}&#xA;],&#xA;pages: [&#xA;{{statements:pages}}&#xA;]&#xA;});">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>theme</orderedInputNames>
    <orderedInputNames>dataSources</orderedInputNames>
    <orderedInputNames>pages</orderedInputNames>
    <fields name="name" defaultValue="Task Tracker" required="true" lowerBound="1" uiWidget="text" uiLabel="App name" uiGroup="App" uiOrder="1" uiVariant="default"/>
    <fields name="theme" fieldType="DROPDOWN" defaultValue="light" uiWidget="select" uiLabel="Theme" uiGroup="App" uiOrder="2" uiVariant="default">
      <options value="light" label="Light"/>
      <options value="dark" label="Dark"/>
      <options value="system" label="System"/>
    </fields>
    <statementInputs name="dataSources" checkType="DataSource" lowerBound="1" upperBound="20" uiWidget="text" uiLabel="Data sources" uiGroup="Data" uiOrder="3" uiVariant="default"/>
    <statementInputs name="pages" checkType="Page" lowerBound="1" upperBound="20" uiWidget="text" uiLabel="Pages" uiGroup="Pages" uiOrder="4" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="Page" label="Page" colour="260" categoryName="Pages" connectionType="TYPED" connectionTypeName="Page" inputsInline="true" tooltip="A navigable page with design settings, components and lifecycle actions." codeTemplate="page(&quot;{{title}}&quot;, {&#xA;route: &quot;{{route}}&quot;,&#xA;layout: &quot;{{layout}}&quot;,&#xA;navigation: &quot;{{navigationStyle}}&quot;,&#xA;backgroundColor: &quot;{{backgroundColor}}&quot;,&#xA;scrollable: &quot;{{scrollable}}&quot; === &quot;TRUE&quot;,&#xA;onEnter: [&#xA;{{statements:onEnter}}&#xA;],&#xA;components: [&#xA;{{statements:components}}&#xA;]&#xA;});" idFieldName="route">
    <orderedInputNames>title</orderedInputNames>
    <orderedInputNames>route</orderedInputNames>
    <orderedInputNames>layout</orderedInputNames>
    <orderedInputNames>navigationStyle</orderedInputNames>
    <orderedInputNames>backgroundColor</orderedInputNames>
    <orderedInputNames>scrollable</orderedInputNames>
    <orderedInputNames>tags</orderedInputNames>
    <orderedInputNames>components</orderedInputNames>
    <orderedInputNames>onEnter</orderedInputNames>
    <fields name="title" defaultValue="Home" required="true" lowerBound="1" uiWidget="text" uiLabel="Title" uiGroup="Page" uiOrder="1" uiVariant="default"/>
    <fields name="route" defaultValue="/home" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Route" uiGroup="Page" uiOrder="2" uiVariant="default"/>
    <fields name="layout" fieldType="DROPDOWN" defaultValue="column" uiWidget="select" uiLabel="Layout" uiGroup="Design" uiOrder="3" uiVariant="default">
      <options value="column" label="Column"/>
      <options value="row" label="Row"/>
      <options value="grid" label="Grid"/>
      <options value="tabs" label="Tabs"/>
    </fields>
    <fields name="navigationStyle" fieldType="DROPDOWN" defaultValue="standard" uiWidget="select" uiLabel="Navigation" uiGroup="Design" uiOrder="4" uiVariant="default">
      <options value="standard" label="Standard"/>
      <options value="none" label="No navigation"/>
      <options value="bottomTabs" label="Bottom tabs"/>
      <options value="drawer" label="Drawer"/>
    </fields>
    <fields name="backgroundColor" fieldType="COLOUR" defaultValue="#ffffff" uiWidget="color" uiLabel="Background" uiGroup="Design" uiOrder="5" uiVariant="default"/>
    <fields name="scrollable" fieldType="BOOLEAN" defaultValue="true" uiWidget="checkbox" uiLabel="Scrollable" uiGroup="Design" uiOrder="6" uiVariant="default"/>
    <fields name="tags" defaultValue="work&#xA;mobile" upperBound="8" unique="false" ordered="false" uiWidget="textarea" uiLabel="Tags" uiGroup="Page" uiOrder="7" uiVariant="default"/>
    <statementInputs name="components" checkType="Component" lowerBound="1" upperBound="40" uiWidget="text" uiLabel="Components" uiGroup="Components" uiOrder="8" uiVariant="default"/>
    <statementInputs name="onEnter" checkType="Action" upperBound="10" uiWidget="text" uiLabel="On enter" uiGroup="Actions" uiOrder="9" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="Component" label="Component" abstract="true" connectionType="TYPED" connectionTypeName="Component" inputsInline="true"/>
  <blockTypes typeName="TextLabel" label="Text" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="text({{value:content}}, { variant: &quot;{{textStyle}}&quot;, align: &quot;{{alignment}}&quot; });">
    <orderedInputNames>content</orderedInputNames>
    <orderedInputNames>textStyle</orderedInputNames>
    <orderedInputNames>alignment</orderedInputNames>
    <fields name="textStyle" fieldType="DROPDOWN" defaultValue="body" uiWidget="select" uiLabel="Variant" uiGroup="Text" uiOrder="2" uiVariant="default">
      <options value="title" label="Title"/>
      <options value="subtitle" label="Subtitle"/>
      <options value="body" label="Body"/>
      <options value="caption" label="Caption"/>
    </fields>
    <fields name="alignment" fieldType="DROPDOWN" defaultValue="start" uiWidget="select" uiLabel="Align" uiGroup="Text" uiOrder="3" uiVariant="default">
      <options value="start" label="Start"/>
      <options value="center" label="Center"/>
      <options value="end" label="End"/>
    </fields>
    <valueInputs name="content" checkType="TextExpression" shadowBlockType="TextLiteral" uiWidget="text" uiLabel="Text" uiGroup="Text" uiOrder="1" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="Button" label="Button" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="button(&quot;{{labelText}}&quot;, &quot;{{style}}&quot;, () => {&#xA;{{statements:onClick}}&#xA;});">
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>style</orderedInputNames>
    <orderedInputNames>onClick</orderedInputNames>
    <fields name="labelText" defaultValue="Save" required="true" uiWidget="text" uiLabel="Text" uiGroup="Button" uiOrder="1" uiVariant="default"/>
    <fields name="style" fieldType="DROPDOWN" defaultValue="primary" uiWidget="select" uiLabel="Style" uiGroup="Button" uiOrder="2" uiVariant="default">
      <options value="primary" label="Primary"/>
      <options value="secondary" label="Secondary"/>
      <options value="danger" label="Danger"/>
      <options value="ghost" label="Ghost"/>
    </fields>
    <statementInputs name="onClick" checkType="Action" upperBound="10" uiWidget="text" uiLabel="On click" uiGroup="Button" uiOrder="3" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="TextInput" label="Text input" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="textInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{hint}}&quot;, {&#xA;type: &quot;{{inputType}}&quot;,&#xA;mandatory: &quot;{{mandatory}}&quot; === &quot;TRUE&quot;&#xA;});" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>hint</orderedInputNames>
    <orderedInputNames>inputType</orderedInputNames>
    <orderedInputNames>mandatory</orderedInputNames>
    <fields name="name" defaultValue="taskTitle" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Input" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Task title" required="true" uiWidget="text" uiLabel="Label" uiGroup="Input" uiOrder="2" uiVariant="default"/>
    <fields name="hint" defaultValue="What needs to be done?" required="true" uiWidget="text" uiLabel="Placeholder" uiGroup="Input" uiOrder="3" uiVariant="default"/>
    <fields name="inputType" fieldType="DROPDOWN" defaultValue="plainText" uiWidget="select" uiLabel="Input type" uiGroup="Input" uiOrder="4" uiVariant="default">
      <options value="plainText" label="Text"/>
      <options value="email" label="Email"/>
      <options value="password" label="Password"/>
      <options value="numeric" label="Number"/>
    </fields>
    <fields name="mandatory" fieldType="BOOLEAN" defaultValue="true" uiWidget="checkbox" uiLabel="Required" uiGroup="Input" uiOrder="5" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="TextArea" label="Text area" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="textArea(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{hint}}&quot;, { rows: {{rows}}, mandatory: &quot;{{mandatory}}&quot; === &quot;TRUE&quot; });" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>hint</orderedInputNames>
    <orderedInputNames>rows</orderedInputNames>
    <orderedInputNames>mandatory</orderedInputNames>
    <fields name="name" defaultValue="notes" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Text area" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Notes" required="true" uiWidget="text" uiLabel="Label" uiGroup="Text area" uiOrder="2" uiVariant="default"/>
    <fields name="hint" defaultValue="Add details" uiWidget="text" uiLabel="Placeholder" uiGroup="Text area" uiOrder="3" uiVariant="default"/>
    <fields name="rows" fieldType="INTEGER" defaultValue="4" min="2" max="12" uiWidget="number" uiLabel="Rows" uiGroup="Text area" uiOrder="4" uiVariant="default"/>
    <fields name="mandatory" fieldType="BOOLEAN" defaultValue="false" uiWidget="checkbox" uiLabel="Required" uiGroup="Text area" uiOrder="5" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="ImageView" label="Image" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="image({{value:url}}, &quot;{{altText}}&quot;, &quot;{{fit}}&quot;);">
    <orderedInputNames>url</orderedInputNames>
    <orderedInputNames>altText</orderedInputNames>
    <orderedInputNames>fit</orderedInputNames>
    <fields name="altText" defaultValue="Preview" uiWidget="text" uiLabel="Alt text" uiGroup="Image" uiOrder="2" uiVariant="default"/>
    <fields name="fit" fieldType="DROPDOWN" defaultValue="cover" uiWidget="select" uiLabel="Fit" uiGroup="Image" uiOrder="3" uiVariant="default">
      <options value="cover" label="Cover"/>
      <options value="contain" label="Contain"/>
      <options value="fill" label="Fill"/>
    </fields>
    <valueInputs name="url" checkType="TextExpression" shadowBlockType="TextLiteral" uiWidget="text" uiLabel="URL" uiGroup="Image" uiOrder="1" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="ListView" label="List view" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="listView(&quot;{{source}}&quot;, { title: {{value:itemTitle}}, emptyText: &quot;{{emptyText}}&quot; });">
    <orderedInputNames>source</orderedInputNames>
    <orderedInputNames>itemTitle</orderedInputNames>
    <orderedInputNames>emptyText</orderedInputNames>
    <fields name="emptyText" defaultValue="No items yet" uiWidget="text" uiLabel="Empty text" uiGroup="List" uiOrder="3" uiVariant="default"/>
    <referenceFields name="source" targetTypeName="DataSource" required="true" lowerBound="1" uiWidget="reference-select" uiLabel="Source" uiGroup="List" uiOrder="1" uiVariant="default" referenceLabelField="name"/>
    <valueInputs name="itemTitle" checkType="TextExpression" shadowBlockType="TextLiteral" uiWidget="text" uiLabel="Item title" uiGroup="List" uiOrder="2" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="ToggleSwitch" label="Switch" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="toggle(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{defaultOn}}&quot; === &quot;TRUE&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>defaultOn</orderedInputNames>
    <fields name="name" defaultValue="notifyMe" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Switch" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Notify me" required="true" uiWidget="text" uiLabel="Label" uiGroup="Switch" uiOrder="2" uiVariant="default"/>
    <fields name="defaultOn" fieldType="BOOLEAN" defaultValue="false" uiWidget="switch" uiLabel="Default on" uiGroup="Switch" uiOrder="3" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="SelectInput" label="Select" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="selectInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{optionsText}}&quot;, &quot;{{initialValue}}&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>optionsText</orderedInputNames>
    <orderedInputNames>initialValue</orderedInputNames>
    <orderedInputNames>mandatory</orderedInputNames>
    <fields name="name" defaultValue="priority" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Select" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Priority" required="true" uiWidget="text" uiLabel="Label" uiGroup="Select" uiOrder="2" uiVariant="default"/>
    <fields name="optionsText" defaultValue="Low&#xA;Medium&#xA;High" required="true" lowerBound="1" upperBound="20" uiWidget="textarea" uiLabel="Options" uiGroup="Select" uiOrder="3" uiVariant="default"/>
    <fields name="initialValue" defaultValue="Medium" uiWidget="text" uiLabel="Initial value" uiGroup="Select" uiOrder="4" uiVariant="default"/>
    <fields name="mandatory" fieldType="BOOLEAN" defaultValue="false" uiWidget="checkbox" uiLabel="Required" uiGroup="Select" uiOrder="5" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="CheckboxInput" label="Checkbox" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="checkboxInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{defaultChecked}}&quot; === &quot;TRUE&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>defaultChecked</orderedInputNames>
    <fields name="name" defaultValue="acceptedTerms" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Checkbox" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="I agree" required="true" uiWidget="text" uiLabel="Label" uiGroup="Checkbox" uiOrder="2" uiVariant="default"/>
    <fields name="defaultChecked" fieldType="BOOLEAN" defaultValue="false" uiWidget="checkbox" uiLabel="Checked" uiGroup="Checkbox" uiOrder="3" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="RadioGroup" label="Radio group" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="radioGroup(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{optionsText}}&quot;, &quot;{{initialValue}}&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>optionsText</orderedInputNames>
    <orderedInputNames>initialValue</orderedInputNames>
    <fields name="name" defaultValue="status" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Radio" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Status" required="true" uiWidget="text" uiLabel="Label" uiGroup="Radio" uiOrder="2" uiVariant="default"/>
    <fields name="optionsText" defaultValue="Open&#xA;In progress&#xA;Done" required="true" lowerBound="2" upperBound="10" uiWidget="textarea" uiLabel="Options" uiGroup="Radio" uiOrder="3" uiVariant="default"/>
    <fields name="initialValue" defaultValue="Open" uiWidget="text" uiLabel="Initial value" uiGroup="Radio" uiOrder="4" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="NumberInput" label="Number input" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="numberInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, {{initialValue}}, {{minValue}}, {{maxValue}}, {{stepValue}});" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>initialValue</orderedInputNames>
    <orderedInputNames>minValue</orderedInputNames>
    <orderedInputNames>maxValue</orderedInputNames>
    <orderedInputNames>stepValue</orderedInputNames>
    <fields name="name" defaultValue="estimate" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Number" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Estimate" required="true" uiWidget="text" uiLabel="Label" uiGroup="Number" uiOrder="2" uiVariant="default"/>
    <fields name="initialValue" fieldType="INTEGER" defaultValue="1" min="0" max="100" uiWidget="number" uiLabel="Initial value" uiGroup="Number" uiOrder="3" uiVariant="default"/>
    <fields name="minValue" fieldType="INTEGER" defaultValue="0" uiWidget="number" uiLabel="Min" uiGroup="Number" uiOrder="4" uiVariant="default"/>
    <fields name="maxValue" fieldType="INTEGER" defaultValue="100" uiWidget="number" uiLabel="Max" uiGroup="Number" uiOrder="5" uiVariant="default"/>
    <fields name="stepValue" fieldType="INTEGER" defaultValue="1" min="1" max="20" uiWidget="number" uiLabel="Step" uiGroup="Number" uiOrder="6" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="SliderInput" label="Slider" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="sliderInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, {{initialValue}}, {{minValue}}, {{maxValue}}, {{stepValue}});" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>initialValue</orderedInputNames>
    <orderedInputNames>minValue</orderedInputNames>
    <orderedInputNames>maxValue</orderedInputNames>
    <orderedInputNames>stepValue</orderedInputNames>
    <fields name="name" defaultValue="progress" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Slider" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Progress" required="true" uiWidget="text" uiLabel="Label" uiGroup="Slider" uiOrder="2" uiVariant="default"/>
    <fields name="initialValue" fieldType="INTEGER" defaultValue="50" min="0" max="100" uiWidget="slider" uiLabel="Initial value" uiGroup="Slider" uiOrder="3" uiVariant="default"/>
    <fields name="minValue" fieldType="INTEGER" defaultValue="0" uiWidget="number" uiLabel="Min" uiGroup="Slider" uiOrder="4" uiVariant="default"/>
    <fields name="maxValue" fieldType="INTEGER" defaultValue="100" uiWidget="number" uiLabel="Max" uiGroup="Slider" uiOrder="5" uiVariant="default"/>
    <fields name="stepValue" fieldType="INTEGER" defaultValue="5" min="1" max="20" uiWidget="number" uiLabel="Step" uiGroup="Slider" uiOrder="6" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="DateInput" label="Date input" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="dateInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{initialValue}}&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>initialValue</orderedInputNames>
    <orderedInputNames>mandatory</orderedInputNames>
    <fields name="name" defaultValue="dueDate" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Date" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Due date" required="true" uiWidget="text" uiLabel="Label" uiGroup="Date" uiOrder="2" uiVariant="default"/>
    <fields name="initialValue" defaultValue="2026-06-14" uiWidget="text" uiLabel="Initial value" uiGroup="Date" uiOrder="3" uiVariant="default"/>
    <fields name="mandatory" fieldType="BOOLEAN" defaultValue="false" uiWidget="checkbox" uiLabel="Required" uiGroup="Date" uiOrder="4" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="TimeInput" label="Time input" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="timeInput(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{initialValue}}&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>initialValue</orderedInputNames>
    <orderedInputNames>mandatory</orderedInputNames>
    <fields name="name" defaultValue="reminderTime" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="Time" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Reminder time" required="true" uiWidget="text" uiLabel="Label" uiGroup="Time" uiOrder="2" uiVariant="default"/>
    <fields name="initialValue" defaultValue="09:00" uiWidget="text" uiLabel="Initial value" uiGroup="Time" uiOrder="3" uiVariant="default"/>
    <fields name="mandatory" fieldType="BOOLEAN" defaultValue="false" uiWidget="checkbox" uiLabel="Required" uiGroup="Time" uiOrder="4" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="FileUpload" label="File upload" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="fileUpload(&quot;{{name}}&quot;, &quot;{{labelText}}&quot;, &quot;{{acceptTypes}}&quot;);" idFieldName="name">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>labelText</orderedInputNames>
    <orderedInputNames>acceptTypes</orderedInputNames>
    <orderedInputNames>multipleFiles</orderedInputNames>
    <fields name="name" defaultValue="attachment" required="true" lowerBound="1" id="true" uiWidget="text" uiLabel="Name" uiGroup="File" uiOrder="1" uiVariant="default"/>
    <fields name="labelText" defaultValue="Attachment" required="true" uiWidget="text" uiLabel="Label" uiGroup="File" uiOrder="2" uiVariant="default"/>
    <fields name="acceptTypes" defaultValue=".png,.jpg,.pdf" required="true" lowerBound="1" upperBound="10" ordered="false" uiWidget="text" uiLabel="Accept" uiGroup="File" uiOrder="3" uiVariant="default"/>
    <fields name="multipleFiles" fieldType="BOOLEAN" defaultValue="false" uiWidget="checkbox" uiLabel="Multiple" uiGroup="File" uiOrder="4" uiVariant="default"/>
  </blockTypes>
  <blockTypes typeName="TableView" label="Table" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true" codeTemplate="tableView(&quot;{{source}}&quot;, &quot;{{columnsText}}&quot;);">
    <orderedInputNames>source</orderedInputNames>
    <orderedInputNames>columnsText</orderedInputNames>
    <orderedInputNames>emptyText</orderedInputNames>
    <fields name="columnsText" defaultValue="title&#xA;status&#xA;subtitle" required="true" lowerBound="1" upperBound="8" uiWidget="textarea" uiLabel="Columns" uiGroup="Table" uiOrder="2" uiVariant="default"/>
    <fields name="emptyText" defaultValue="No rows" uiWidget="text" uiLabel="Empty text" uiGroup="Table" uiOrder="3" uiVariant="default"/>
