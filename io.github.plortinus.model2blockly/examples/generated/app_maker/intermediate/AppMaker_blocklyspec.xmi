  </validations>
  <validations type="EXPRESSION" name="DataSource_dataSourceRetryRange" ownerType="DataSource" expression="number('retryCount') >= 0 &amp;&amp; number('retryCount') &lt;= 10" message="Retry count must be between 0 and 10.">
    <visualBlock blocklyBlockType="validation_expression_rule">
      <fields name="TYPE" value="DataSource"/>
      <fields name="EXPRESSION" value="number('retryCount') >= 0 &amp;&amp; number('retryCount') &lt;= 10"/>
      <inputs name="CONDITION">
        <expression operator="AND">
          <children kind="LOGIC_COMPARE" operator="GTE">
            <children kind="FIELD_NUMBER" fieldName="retryCount"/>
            <children kind="NUMBER_LITERAL" literal="0"/>
          </children>
          <children kind="LOGIC_COMPARE" operator="LTE">
            <children kind="FIELD_NUMBER" fieldName="retryCount"/>
            <children kind="NUMBER_LITERAL" literal="10"/>
          </children>
        </expression>
      </inputs>
    </visualBlock>
    <visualExpression operator="AND">
      <children kind="LOGIC_COMPARE" operator="GTE">
        <children kind="FIELD_NUMBER" fieldName="retryCount"/>
        <children kind="NUMBER_LITERAL" literal="0"/>
      </children>
      <children kind="LOGIC_COMPARE" operator="LTE">
        <children kind="FIELD_NUMBER" fieldName="retryCount"/>
        <children kind="NUMBER_LITERAL" literal="10"/>
      </children>
    </visualExpression>
  </validations>
  <validations type="EXPRESSION" name="Page_pageRouteStartsWithSlash" ownerType="Page" expression="value('route') !== '' &amp;&amp; value('route').startsWith('/')" message="Page route must start with /.">
