  <validations type="EXPRESSION" name="DateInput_dateInputFormat" ownerType="DateInput" expression="!has('initialValue') || (value('initialValue').length === 10 &amp;&amp; value('initialValue').charAt(4) === '-' &amp;&amp; value('initialValue').charAt(7) === '-')" message="Date input initial value should use YYYY-MM-DD.">
