<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Outputblocks" nsURI="https://plortinus.github.io/model2blockly/examples/outputblocks" nsPrefix="outputblocks" codeLanguage="text" codeFileExtension="txt">
  <categories name="Rules" label="Rules" colour="260"/>
  <categories name="Expressions" label="Expressions" colour="230"/>
  <blockTypes typeName="Threshold" label="Threshold" colour="260" categoryName="Rules">
    <orderedInputNames>value</orderedInputNames>
    <valueInputs name="value" checkType="NumberExpression" shadowBlockType="NumberLiteral"/>
  </blockTypes>
  <blockTypes typeName="NumberExpression" label="NumberExpression" colour="230" categoryName="Expressions" abstract="true" connectionType="OUTPUT" outputType="NumberExpression"/>
  <blockTypes typeName="NumberLiteral" label="NumberLiteral" colour="230" categoryName="Expressions" superTypeName="NumberExpression" connectionType="OUTPUT_TYPED" outputType="NumberExpression" inputsInline="true">
    <orderedInputNames>value</orderedInputNames>
    <fields name="value" fieldType="INTEGER" defaultValue="5"/>
  </blockTypes>
  <blockTypes typeName="Add" label="Add" colour="230" categoryName="Expressions" superTypeName="NumberExpression" connectionType="OUTPUT_TYPED" outputType="NumberExpression" message0="%1 + %2">
    <orderedInputNames>left</orderedInputNames>
    <orderedInputNames>right</orderedInputNames>
    <valueInputs name="left" checkType="NumberExpression" shadowBlockType="NumberLiteral"/>
    <valueInputs name="right" checkType="NumberExpression" shadowBlockType="NumberLiteral"/>
  </blockTypes>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
