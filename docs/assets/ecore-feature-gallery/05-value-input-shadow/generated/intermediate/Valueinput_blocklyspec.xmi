<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Valueinput" nsURI="https://plortinus.github.io/model2blockly/examples/valueinput" nsPrefix="valueinput" codeLanguage="text" codeFileExtension="txt">
  <categories name="Components" label="Components" colour="160"/>
  <categories name="Expressions" label="Expressions" colour="230"/>
  <blockTypes typeName="TextLabel" label="TextLabel" colour="160" categoryName="Components">
    <orderedInputNames>content</orderedInputNames>
    <valueInputs name="content" checkType="TextExpression" shadowBlockType="TextLiteral" uiLabel="Text"/>
  </blockTypes>
  <blockTypes typeName="TextExpression" label="TextExpression" colour="230" categoryName="Expressions" abstract="true" connectionType="OUTPUT" outputType="TextExpression"/>
  <blockTypes typeName="TextLiteral" label="TextLiteral" colour="230" categoryName="Expressions" superTypeName="TextExpression" connectionType="OUTPUT_TYPED" outputType="TextExpression" inputsInline="true">
    <orderedInputNames>content</orderedInputNames>
    <fields name="content" defaultValue="Hello"/>
  </blockTypes>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
