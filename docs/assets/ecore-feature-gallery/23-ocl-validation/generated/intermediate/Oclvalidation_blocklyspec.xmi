<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Oclvalidation" nsURI="https://plortinus.github.io/model2blockly/examples/oclvalidation" nsPrefix="oclvalidation" codeLanguage="text" codeFileExtension="txt">
  <categories name="Validation" label="Validation" colour="20"/>
  <blockTypes typeName="Checklist" label="Checklist" colour="20" categoryName="Validation" connectionType="NONE">
    <orderedInputNames>name</orderedInputNames>
    <orderedInputNames>items</orderedInputNames>
    <fields name="name" defaultValue="Launch"/>
    <statementInputs name="items" checkType="ChecklistItem"/>
  </blockTypes>
  <blockTypes typeName="ChecklistItem" label="ChecklistItem" colour="110" categoryName="Validation" connectionType="TYPED" connectionTypeName="ChecklistItem">
    <orderedInputNames>text</orderedInputNames>
    <fields name="text" defaultValue="Review"/>
  </blockTypes>
  <validations type="EXPRESSION" name="Checklist_HasName" ownerType="Checklist" expression="has(&quot;name&quot;)" message="Constraint &quot;HasName&quot; is violated on Checklist.">
    <visualBlock blocklyBlockType="validation_expression_rule">
      <fields name="TYPE" value="Checklist"/>
      <fields name="EXPRESSION" value="has(&quot;name&quot;)"/>
      <inputs name="CONDITION">
        <expression kind="FIELD_EXISTS" fieldName="name"/>
      </inputs>
    </visualBlock>
    <visualExpression kind="FIELD_EXISTS" fieldName="name"/>
  </validations>
  <validations type="EXPRESSION" name="Checklist_HasItems" ownerType="Checklist" expression="size(&quot;items&quot;) >= 1" message="Constraint &quot;HasItems&quot; is violated on Checklist.">
    <visualBlock blocklyBlockType="validation_expression_rule">
      <fields name="TYPE" value="Checklist"/>
      <fields name="EXPRESSION" value="size(&quot;items&quot;) >= 1"/>
      <inputs name="CONDITION">
        <expression kind="LOGIC_COMPARE" operator="GTE">
          <children kind="INPUT_COUNT" fieldName="items"/>
          <children kind="NUMBER_LITERAL" literal="1"/>
        </expression>
      </inputs>
    </visualBlock>
    <visualExpression kind="LOGIC_COMPARE" operator="GTE">
      <children kind="INPUT_COUNT" fieldName="items"/>
      <children kind="NUMBER_LITERAL" literal="1"/>
    </visualExpression>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
