<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Idreferencelabel" nsURI="https://plortinus.github.io/model2blockly/examples/idreferencelabel" nsPrefix="idreferencelabel" codeLanguage="text" codeFileExtension="txt">
  <categories name="Library" label="Library" colour="260"/>
  <blockTypes typeName="Library" label="Library" colour="260" categoryName="Library" connectionType="NONE">
    <orderedInputNames>authors</orderedInputNames>
    <orderedInputNames>books</orderedInputNames>
    <statementInputs name="authors" checkType="Author" lowerBound="1"/>
    <statementInputs name="books" checkType="Book" lowerBound="1"/>
  </blockTypes>
  <blockTypes typeName="Author" label="Author" colour="60" categoryName="Library" connectionType="TYPED" connectionTypeName="Author" inputsInline="true" idFieldName="authorId">
    <orderedInputNames>authorId</orderedInputNames>
    <orderedInputNames>displayName</orderedInputNames>
    <fields name="authorId" defaultValue="author-1" required="true" lowerBound="1" id="true"/>
    <fields name="displayName" defaultValue="Ada Lovelace"/>
  </blockTypes>
  <blockTypes typeName="Book" label="Book" colour="120" categoryName="Library" connectionType="TYPED" connectionTypeName="Book" inputsInline="true">
    <orderedInputNames>title</orderedInputNames>
    <orderedInputNames>author</orderedInputNames>
    <fields name="title" defaultValue="Notes"/>
    <referenceFields name="author" targetTypeName="Author" required="true" lowerBound="1" referenceLabelField="authorId"/>
  </blockTypes>
  <validations type="CARDINALITY" name="Library_authors" ownerType="Library" containmentName="authors" lowerBound="1">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Library"/>
      <fields name="INPUT" value="authors"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="unbounded"/>
    </visualBlock>
    <visualExpression kind="LOGIC_COMPARE" operator="GTE">
      <children kind="INPUT_COUNT" fieldName="authors"/>
      <children kind="NUMBER_LITERAL" literal="1"/>
    </visualExpression>
  </validations>
  <validations type="CARDINALITY" name="Library_books" ownerType="Library" containmentName="books" lowerBound="1">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Library"/>
      <fields name="INPUT" value="books"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="unbounded"/>
    </visualBlock>
    <visualExpression kind="LOGIC_COMPARE" operator="GTE">
      <children kind="INPUT_COUNT" fieldName="books"/>
      <children kind="NUMBER_LITERAL" literal="1"/>
    </visualExpression>
  </validations>
  <validations type="REQUIRED" name="Author_authorId_required" ownerType="Author" fieldName="authorId" fieldKind="attribute">
    <visualBlock blocklyBlockType="validation_required_field">
      <fields name="TYPE" value="Author"/>
      <fields name="FIELD" value="authorId"/>
      <fields name="FIELD_KIND" value="attribute"/>
    </visualBlock>
    <visualExpression kind="FIELD_EXISTS" fieldName="authorId"/>
  </validations>
  <validations type="REQUIRED" name="Book_author_required" ownerType="Book" fieldName="author" fieldKind="reference">
    <visualBlock blocklyBlockType="validation_required_field">
      <fields name="TYPE" value="Book"/>
      <fields name="FIELD" value="author"/>
      <fields name="FIELD_KIND" value="reference"/>
    </visualBlock>
    <visualExpression kind="FIELD_EXISTS" fieldName="author"/>
  </validations>
  <validations type="UNIQUE" name="Author_authorId_unique" ownerType="Author" fieldName="authorId" fieldKind="id">
    <visualBlock blocklyBlockType="validation_type_field_unique">
      <fields name="TYPE" value="Author"/>
      <fields name="FIELD" value="authorId"/>
    </visualBlock>
    <visualExpression kind="TYPE_FIELD_UNIQUE" fieldName="authorId" typeName="Author"/>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
