<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Statementinput" nsURI="https://plortinus.github.io/model2blockly/examples/statementinput" nsPrefix="statementinput" codeLanguage="text" codeFileExtension="txt">
  <categories name="Layout" label="Layout" colour="260"/>
  <categories name="Components" label="Components" colour="160"/>
  <blockTypes typeName="Page" label="Page" colour="260" categoryName="Layout" connectionType="NONE">
    <orderedInputNames>title</orderedInputNames>
    <orderedInputNames>components</orderedInputNames>
    <fields name="title" defaultValue="Home"/>
    <statementInputs name="components" checkType="Component" lowerBound="1" upperBound="4" uiLabel="Components"/>
  </blockTypes>
  <blockTypes typeName="Component" label="Component" colour="160" categoryName="Components" abstract="true" connectionType="TYPED" connectionTypeName="Component"/>
  <blockTypes typeName="Button" label="Button" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component">
    <orderedInputNames>label</orderedInputNames>
    <fields name="label" defaultValue="Save"/>
  </blockTypes>
  <validations type="CARDINALITY" name="Page_components" ownerType="Page" containmentName="components" lowerBound="1" upperBound="4">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Page"/>
      <fields name="INPUT" value="components"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="4"/>
    </visualBlock>
    <visualExpression operator="AND">
      <children kind="LOGIC_COMPARE" operator="GTE">
        <children kind="INPUT_COUNT" fieldName="components"/>
        <children kind="NUMBER_LITERAL" literal="1"/>
      </children>
      <children kind="LOGIC_COMPARE" operator="LTE">
        <children kind="INPUT_COUNT" fieldName="components"/>
        <children kind="NUMBER_LITERAL" literal="4"/>
      </children>
    </visualExpression>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
