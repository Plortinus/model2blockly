<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Autocategory" nsURI="https://plortinus.github.io/model2blockly/examples/autocategory" nsPrefix="autocategory" codeLanguage="text" codeFileExtension="txt">
  <categories name="Sprite" label="Sprite" colour="0"/>
  <categories name="Command" label="Command" colour="180">
    <children name="MovementCommand" label="MovementCommand" colour="180"/>
  </categories>
  <blockTypes typeName="Sprite" label="Sprite" categoryName="Sprite" connectionType="NONE">
    <orderedInputNames>commands</orderedInputNames>
    <statementInputs name="commands" checkType="Command" lowerBound="1" upperBound="4"/>
  </blockTypes>
  <blockTypes typeName="Command" label="Command" abstract="true" connectionType="TYPED" connectionTypeName="Command"/>
  <blockTypes typeName="MovementCommand" label="MovementCommand" abstract="true" superTypeName="Command" connectionType="TYPED" connectionTypeName="Command"/>
  <blockTypes typeName="Move" label="Move" categoryName="MovementCommand" superTypeName="MovementCommand" connectionType="TYPED" connectionTypeName="Command">
    <orderedInputNames>steps</orderedInputNames>
    <fields name="steps" fieldType="INTEGER" defaultValue="10"/>
  </blockTypes>
  <blockTypes typeName="Turn" label="Turn" categoryName="MovementCommand" superTypeName="MovementCommand" connectionType="TYPED" connectionTypeName="Command">
    <orderedInputNames>degrees</orderedInputNames>
    <fields name="degrees" fieldType="INTEGER" defaultValue="15"/>
  </blockTypes>
  <blockTypes typeName="Say" label="Say" categoryName="Command" superTypeName="Command" connectionType="TYPED" connectionTypeName="Command">
    <orderedInputNames>text</orderedInputNames>
    <fields name="text" defaultValue="Hello"/>
  </blockTypes>
  <validations type="CARDINALITY" name="Sprite_commands" ownerType="Sprite" containmentName="commands" lowerBound="1" upperBound="4">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Sprite"/>
      <fields name="INPUT" value="commands"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="4"/>
    </visualBlock>
    <visualExpression operator="AND">
      <children kind="LOGIC_COMPARE" operator="GTE">
        <children kind="INPUT_COUNT" fieldName="commands"/>
        <children kind="NUMBER_LITERAL" literal="1"/>
      </children>
      <children kind="LOGIC_COMPARE" operator="LTE">
        <children kind="INPUT_COUNT" fieldName="commands"/>
        <children kind="NUMBER_LITERAL" literal="4"/>
      </children>
    </visualExpression>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
