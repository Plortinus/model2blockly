<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Abstracttype" nsURI="https://plortinus.github.io/model2blockly/examples/abstracttype" nsPrefix="abstracttype" codeLanguage="text" codeFileExtension="txt">
  <categories name="Screens" label="Screens" colour="260"/>
  <categories name="Components" label="Components" colour="160"/>
  <blockTypes typeName="Screen" label="Screen" colour="260" categoryName="Screens" connectionType="NONE">
    <orderedInputNames>components</orderedInputNames>
    <statementInputs name="components" checkType="Component" lowerBound="1" upperBound="4"/>
  </blockTypes>
  <blockTypes typeName="Component" label="Component" colour="160" categoryName="Components" abstract="true" connectionType="TYPED" connectionTypeName="Component"/>
  <blockTypes typeName="Text" label="Text" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component">
    <orderedInputNames>value</orderedInputNames>
    <fields name="value" defaultValue="Name"/>
  </blockTypes>
  <blockTypes typeName="Image" label="Image" colour="160" categoryName="Components" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component">
    <orderedInputNames>url</orderedInputNames>
    <fields name="url" defaultValue="https://example.com/avatar.png"/>
  </blockTypes>
  <validations type="CARDINALITY" name="Screen_components" ownerType="Screen" containmentName="components" lowerBound="1" upperBound="4">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Screen"/>
      <fields name="INPUT" value="components"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="4"/>
    </visualBlock>
    <visualExpression operator="AND">
      <children kind="LOGIC_COMPARE" operator="GTE">
        <children kind="INPUT_COUNT" fieldName="components"/>
        <children kind="NUMBER_LITERAL" literal="1"/>
      </children>
      <children kind="LOGIC_COMPARE" operator="LTE">
        <children kind="INPUT_COUNT" fieldName="components"/>
        <children kind="NUMBER_LITERAL" literal="4"/>
      </children>
    </visualExpression>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
