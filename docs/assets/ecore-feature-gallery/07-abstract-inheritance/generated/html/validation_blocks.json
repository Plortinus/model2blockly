    {
      "name": "Screen_components",
      "validationType": "CARDINALITY",
      "targetType": "Screen",
      "message": "Screen.components has invalid cardinality.",
      "blockTree": {
        "type": "validation_rule",
        "fields": {
          "NAME": "Screen_components",
          "TARGET": "Screen",
          "VALIDATION_TYPE": "CARDINALITY",
          "MESSAGE": "Screen.components has invalid cardinality."
        },
        "inputs": {
          "CONDITION": {
            "type": "validation_statement_cardinality",
            "fields": {
              "TYPE": "Screen",
              "INPUT": "components",
              "MIN": "1",
              "MAX": "4"
            }
          }
        }
      },
      "expandedExpression": {
        "type": "logic_operation",
        "fields": { "OP": "AND" },
        "inputs": {
          "A": {
            "type": "logic_compare",
            "fields": { "OP": "GTE" },
            "inputs": {
              "A": {
                "type": "validation_input_count",
                "fields": { "INPUT": "components" }
              },
              "B": {
                "type": "math_number",
                "fields": { "NUM": "1" }
              }
            }
          },
          "B": {
            "type": "logic_compare",
            "fields": { "OP": "LTE" },
            "inputs": {
              "A": {
                "type": "validation_input_count",
                "fields": { "INPUT": "components" }
              },
              "B": {
                "type": "math_number",
                "fields": { "NUM": "4" }
              }
            }
          }
        }
      },
      "generator": {
        "format": "model2blockly.validationGenerator.v1",
        "source": "visualBlock",
        "blockType": "validation_statement_cardinality",
        "runtimeCheck": "statementCardinality",
        "runtimeExpression": "inputCount(\"components\") >= 1 && inputCount(\"components\") <= 4",
        "parameters": {
          "TYPE": "Screen",
          "INPUT": "components",
          "MIN": "1",
          "MAX": "4"
        }
      }
