<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Nestedcategory" nsURI="https://plortinus.github.io/model2blockly/examples/nestedcategory" nsPrefix="nestedcategory" codeLanguage="text" codeFileExtension="txt">
  <categories name="UI" label="UI" colour="260">
    <children name="Screens" label="Screens" colour="260"/>
    <children name="Components" label="Components" colour="160"/>
    <children name="Inputs" label="Inputs" colour="160"/>
    <children name="Actions" label="Actions" colour="160"/>
  </categories>
  <blockTypes typeName="Screen" label="Screen" colour="260" categoryName="Screens" connectionType="NONE">
    <orderedInputNames>controls</orderedInputNames>
    <statementInputs name="controls" checkType="Component" lowerBound="1" upperBound="4"/>
  </blockTypes>
  <blockTypes typeName="Component" label="Component" colour="160" categoryName="Components" abstract="true" connectionType="TYPED" connectionTypeName="Component"/>
  <blockTypes typeName="TextInput" label="TextInput" colour="160" categoryName="Inputs" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true">
    <orderedInputNames>label</orderedInputNames>
    <fields name="label" defaultValue="Name"/>
  </blockTypes>
  <blockTypes typeName="SubmitButton" label="SubmitButton" colour="160" categoryName="Actions" superTypeName="Component" connectionType="TYPED" connectionTypeName="Component" inputsInline="true">
    <orderedInputNames>label</orderedInputNames>
    <fields name="label" defaultValue="Submit"/>
  </blockTypes>
  <validations type="CARDINALITY" name="Screen_controls" ownerType="Screen" containmentName="controls" lowerBound="1" upperBound="4">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Screen"/>
      <fields name="INPUT" value="controls"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="4"/>
    </visualBlock>
    <visualExpression operator="AND">
      <children kind="LOGIC_COMPARE" operator="GTE">
        <children kind="INPUT_COUNT" fieldName="controls"/>
        <children kind="NUMBER_LITERAL" literal="1"/>
      </children>
      <children kind="LOGIC_COMPARE" operator="LTE">
        <children kind="INPUT_COUNT" fieldName="controls"/>
        <children kind="NUMBER_LITERAL" literal="4"/>
      </children>
    </visualExpression>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
