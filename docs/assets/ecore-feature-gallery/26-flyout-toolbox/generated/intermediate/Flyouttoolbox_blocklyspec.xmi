<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Flyouttoolbox" nsURI="https://plortinus.github.io/model2blockly/examples/flyouttoolbox" nsPrefix="flyouttoolbox" toolboxType="flyout" codeLanguage="text" codeFileExtension="txt">
  <categories name="Notes" label="Notes" colour="210"/>
  <blockTypes typeName="QuickNote" label="QuickNote" colour="210" categoryName="Notes" inputsInline="true">
    <orderedInputNames>text</orderedInputNames>
    <fields name="text" defaultValue="One-click block"/>
  </blockTypes>
  <blockTypes typeName="QuickFlag" label="QuickFlag" colour="120" categoryName="Notes" inputsInline="true">
    <orderedInputNames>enabled</orderedInputNames>
    <fields name="enabled" fieldType="BOOLEAN" defaultValue="true"/>
  </blockTypes>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="drag" value="true" valueType="BOOLEAN"/>
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
  <workspaceOptions key="renderer" value="zelos"/>
</blocklyspec:EditorSpec>
