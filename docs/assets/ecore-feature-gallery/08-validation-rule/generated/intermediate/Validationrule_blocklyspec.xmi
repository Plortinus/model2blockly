<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Validationrule" nsURI="https://plortinus.github.io/model2blockly/examples/validationrule" nsPrefix="validationrule" codeLanguage="text" codeFileExtension="txt">
  <categories name="Flow" label="Flow" colour="260"/>
  <categories name="Actions" label="Actions" colour="30"/>
  <blockTypes typeName="Flow" label="Flow" colour="260" categoryName="Flow" connectionType="NONE">
    <orderedInputNames>actions</orderedInputNames>
    <statementInputs name="actions" checkType="Action" lowerBound="1" upperBound="4"/>
  </blockTypes>
  <blockTypes typeName="Action" label="Action" colour="30" categoryName="Actions" abstract="true" connectionType="TYPED" connectionTypeName="Action"/>
  <blockTypes typeName="Alert" label="Alert" colour="30" categoryName="Actions" superTypeName="Action" connectionType="TYPED" connectionTypeName="Action">
    <orderedInputNames>message</orderedInputNames>
    <fields name="message" defaultValue="Leaving page"/>
  </blockTypes>
  <blockTypes typeName="Navigate" label="Navigate" colour="30" categoryName="Actions" superTypeName="Action" connectionType="TYPED" connectionTypeName="Action">
    <orderedInputNames>target</orderedInputNames>
    <fields name="target" defaultValue="details"/>
  </blockTypes>
  <validations name="Navigate_after_Alert" targetType="Navigate" predecessorType="Alert">
    <visualBlock blocklyBlockType="validation_previous_block_is">
      <fields name="TARGET" value="Navigate"/>
      <fields name="TYPE" value="Alert"/>
    </visualBlock>
    <visualExpression kind="PREVIOUS_BLOCK_IS" typeName="Alert"/>
  </validations>
  <validations type="CARDINALITY" name="Flow_actions" ownerType="Flow" containmentName="actions" lowerBound="1" upperBound="4">
    <visualBlock blocklyBlockType="validation_statement_cardinality">
      <fields name="TYPE" value="Flow"/>
      <fields name="INPUT" value="actions"/>
      <fields name="MIN" value="1"/>
      <fields name="MAX" value="4"/>
    </visualBlock>
    <visualExpression operator="AND">
      <children kind="LOGIC_COMPARE" operator="GTE">
        <children kind="INPUT_COUNT" fieldName="actions"/>
        <children kind="NUMBER_LITERAL" literal="1"/>
      </children>
      <children kind="LOGIC_COMPARE" operator="LTE">
        <children kind="INPUT_COUNT" fieldName="actions"/>
        <children kind="NUMBER_LITERAL" literal="4"/>
      </children>
    </visualExpression>
  </validations>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
