<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Subpackages" nsURI="https://plortinus.github.io/model2blockly/examples/subpackages" nsPrefix="subpackages" codeLanguage="text" codeFileExtension="txt">
  <categories name="Root" label="Root" colour="260"/>
  <categories name="Subpackage" label="Subpackage" colour="160"/>
  <blockTypes typeName="Dashboard" label="Dashboard" colour="260" categoryName="Root" inputsInline="true">
    <orderedInputNames>title</orderedInputNames>
    <fields name="title" defaultValue="Metrics"/>
  </blockTypes>
  <blockTypes typeName="Chart" label="Chart" colour="160" categoryName="Subpackage" inputsInline="true">
    <orderedInputNames>series</orderedInputNames>
    <fields name="series" defaultValue="revenue"/>
  </blockTypes>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
