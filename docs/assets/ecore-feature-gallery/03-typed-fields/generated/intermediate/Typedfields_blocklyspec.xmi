<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Typedfields" nsURI="https://plortinus.github.io/model2blockly/examples/typedfields" nsPrefix="typedfields" codeLanguage="text" codeFileExtension="txt">
  <categories name="Fields" label="Fields" colour="20"/>
  <blockTypes typeName="WidgetStyle" label="WidgetStyle" colour="20" categoryName="Fields">
    <orderedInputNames>visible</orderedInputNames>
    <orderedInputNames>width</orderedInputNames>
    <orderedInputNames>accentColor</orderedInputNames>
    <fields name="visible" fieldType="BOOLEAN" defaultValue="true" uiLabel="Visible"/>
    <fields name="width" fieldType="INTEGER" defaultValue="320" min="0" max="960" uiLabel="Width"/>
    <fields name="accentColor" fieldType="COLOUR" defaultValue="#1f6feb" uiLabel="Accent"/>
  </blockTypes>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
