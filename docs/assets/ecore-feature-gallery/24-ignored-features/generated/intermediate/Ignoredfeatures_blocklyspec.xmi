<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Ignoredfeatures" nsURI="https://plortinus.github.io/model2blockly/examples/ignoredfeatures" nsPrefix="ignoredfeatures" codeLanguage="text" codeFileExtension="txt">
  <categories name="Ecore" label="Ecore" colour="210"/>
  <blockTypes typeName="DebugRecord" label="DebugRecord" colour="210" categoryName="Ecore" inputsInline="true">
    <orderedInputNames>visibleName</orderedInputNames>
    <fields name="visibleName" defaultValue="Shown"/>
  </blockTypes>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
