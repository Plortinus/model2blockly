<?xml version="1.0" encoding="UTF-8"?>
<blocklyspec:EditorSpec xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:blocklyspec="http://www.example.org/model2blockly/intermediate/BlocklyEditorSpec" domainName="Fieldoverrides" nsURI="https://plortinus.github.io/model2blockly/examples/fieldoverrides" nsPrefix="fieldoverrides" codeLanguage="text" codeFileExtension="txt">
  <categories name="Fields" label="Fields" colour="190"/>
  <blockTypes typeName="ControlSettings" label="ControlSettings" colour="190" categoryName="Fields" inputsInline="true">
    <orderedInputNames>caption</orderedInputNames>
    <orderedInputNames>ratio</orderedInputNames>
    <orderedInputNames>locked</orderedInputNames>
    <fields name="caption" defaultValue="Volume"/>
    <fields name="ratio" fieldType="FLOAT" defaultValue="0.75" min="0" max="1"/>
    <fields name="locked" fieldType="BOOLEAN" defaultValue="true"/>
  </blockTypes>
  <workspaceOptions key="zoom" valueType="OBJECT">
    <children key="wheel" value="true" valueType="BOOLEAN"/>
    <children key="controls" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="move" valueType="OBJECT">
    <children key="scrollbars" value="true" valueType="BOOLEAN"/>
    <children key="drag" value="true" valueType="BOOLEAN"/>
  </workspaceOptions>
  <workspaceOptions key="renderer" value="zelos"/>
  <workspaceOptions key="trashcan" value="true" valueType="BOOLEAN"/>
</blocklyspec:EditorSpec>
